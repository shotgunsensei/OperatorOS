# OperatorOS Environment Configuration

# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/operatoros

# API server port
API_PORT=5000

# Runner gateway port (when running as separate service)
GATEWAY_PORT=4001

# Gateway URL (how the API reaches the gateway)
GATEWAY_URL=http://localhost:4001

# Runner mode: k8s (requires k3d/kubectl) or docker (requires docker CLI)
RUNNER_MODE=docker

# Docker workspace volume base path (for docker mode)
WORKSPACE_VOLUME_BASE=/tmp/operatoros-workspaces

# Set to "true" to allow unsafe commands (curl, wget, sudo, etc.)
ALLOW_UNSAFE_COMMANDS=false

# Session secret for auth (optional, not used in MVP)
SESSION_SECRET=change-me-in-production
