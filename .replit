modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3002

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=5001 tsx apps/api/src/index.ts & sleep 2 && cd apps/web && NEXT_PUBLIC_API_URL=http://localhost:5001 npx next start -p ${PORT:-5000}"]
build = ["bash", "-c", "export NEXT_PUBLIC_API_URL=http://localhost:5001 && cd apps/web && npx next build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5001 tsx apps/api/src/index.ts & PORT=5002 tsx apps/runner-gateway/src/index.ts & sleep 2 && cd apps/web && NEXT_PUBLIC_API_URL=http://localhost:5001 npx next dev -p 5000"
waitForPort = 5000

[userenv]

[userenv.shared]
ADMIN_EMAIL = "john@shotgunninjas.com"
ADMIN_PASSWORD = "Dr0p$0fJup1t3r"

[userenv.production]
OPERATOROS_BASE_URL = "https://operatoros.net"
STRIPE_MODE = "live"

[userenv.development]
OPERATOROS_BOOTSTRAP_SUPER_ADMIN_EMAIL = "john@shotgunninjas.com"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[agent]
integrations = ["stripe:1.0.0"]
