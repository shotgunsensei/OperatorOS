# =============================================================================
# OperatorOS Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in values. On Replit, set the same keys via
# the Secrets pane instead of committing them to disk.
#
# Legend:
#   [REQUIRED]  must be set for the app to boot
#   [OPTIONAL]  app boots without it; the related feature is disabled and a
#               warning is logged at startup
# =============================================================================


# ---- Core (required) -------------------------------------------------------

# [REQUIRED] PostgreSQL connection string. Used by both the API and migrations.
DATABASE_URL=postgresql://user:pass@localhost:5432/operatoros

# [REQUIRED] Secret used to sign JWT auth tokens AND Fastify cookies. Must be a
# long random string in production. Rotating this value invalidates every
# active session and password-reset token.
SESSION_SECRET=change-me-in-production


# ---- Service ports ---------------------------------------------------------

# [OPTIONAL] API HTTP port. Default 5001 in dev, set by the platform in deploy.
PORT=5001

# [OPTIONAL] Runner gateway port (only when run as a separate service).
GATEWAY_PORT=5002

# [OPTIONAL] How the API reaches the runner gateway.
GATEWAY_URL=http://localhost:5002


# ---- Frontend (Next.js) ---------------------------------------------------

# [OPTIONAL] API base URL the browser/Next.js calls. In Replit deployments the
# API runs in the same container, so the bundled rewrites already proxy
# /api/* -> ${NEXT_PUBLIC_API_URL}/v1/* on localhost. Set this only if you
# host the API on a different origin.
NEXT_PUBLIC_API_URL=http://localhost:5001


# ---- Runner / CDE ---------------------------------------------------------

# [OPTIONAL] Runner mode: `docker` (requires Docker CLI) or `k8s` (requires
# k3d/kubectl). The CDE shell features will be disabled if neither is usable.
RUNNER_MODE=docker

# [OPTIONAL] Workspace volume mount base for docker mode.
WORKSPACE_VOLUME_BASE=/tmp/operatoros-workspaces

# [OPTIONAL] Set to `true` to bypass the CDE command denylist (curl, wget,
# sudo, etc.). DO NOT enable in production.
ALLOW_UNSAFE_COMMANDS=false


# ---- Bootstrap & seeding --------------------------------------------------

# [OPTIONAL] Email of the user who should be promoted to platform `super_admin`
# on every boot. Useful for re-asserting admin after a DB reset. The user must
# already exist (or will be auto-created with the default seed flow).
OPERATOROS_BOOTSTRAP_SUPER_ADMIN_EMAIL=

# [OPTIONAL] Override the default seeded admin/demo accounts.
ADMIN_EMAIL=john@shotgunninjas.com
DEMO_EMAIL=demo@operatoros.com


# ---- AI provider (optional) ----------------------------------------------

# [OPTIONAL] OpenAI key for the AI Assistant + agent loop. If unset, the AI
# module falls back to a deterministic mock provider.
OPENAI_API_KEY=


# ---- Module SSO (optional) ------------------------------------------------

# [OPTIONAL] HMAC secret for cross-module SSO handoff JWTs. If unset:
#   - dev:  Open App falls back to plain URL with a warning banner
#   - prod: Open App fails closed (no handoff issued)
MODULE_SSO_SECRET=


# ---- Module URLs (optional, one per Shotgun module) -----------------------
# When a module URL is missing, the module's "Open App" CTA is hidden and the
# module is shown as `coming_soon` in the marketplace. Setting the URL is what
# makes the module "live" externally.

TRADEFLOWKIT_URL=
TORQUESHED_URL=
TECHDECK_URL=
PULSEDESK_URL=
FAULTLINELAB_URL=
BF_OS_URL=
SNAPPROOFOS_URL=
STUDYFORGE_AI_URL=
NINJA_LAUNCH_KIT_URL=
CALLCOMMAND_AI_URL=
NINJAMATION_URL=


# ---- Stripe billing (optional) -------------------------------------------
# Stripe stays disabled until BOTH a secret key is set AND STRIPE_MODE=live.
# When disabled: billing pages still render, checkout buttons show a
# "configuration needed" state, webhooks return 503. The app never crashes.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# `live` enables real Stripe calls. `test` keeps the SDK guard tripped so no
# checkout sessions are created (safe default for staging).
STRIPE_MODE=test

# Plan price IDs (used by checkout). Missing IDs hide the matching plan card.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

# Add-on price IDs (used by per-module Buy Add-on flow). Missing IDs disable
# the add-on button for that module without crashing.
STRIPE_PRICE_ADDON_TRADEFLOWKIT=
STRIPE_PRICE_ADDON_TORQUESHED=
STRIPE_PRICE_ADDON_TECHDECK=
STRIPE_PRICE_ADDON_PULSEDESK=
STRIPE_PRICE_ADDON_FAULTLINELAB=
STRIPE_PRICE_ADDON_BF_OS=
STRIPE_PRICE_ADDON_SNAPPROOFOS=
